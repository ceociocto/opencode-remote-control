# Telegram Bot Configuration
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Feishu Bot Configuration
# Get credentials from https://open.feishu.cn/app
# Uses WebSocket long connection mode - no tunnel required!
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenCode Configuration (optional)
# OPENCODE_SERVER_URL=http://localhost:3000

# Enable session sharing (default: false)
# WARNING: When enabled, session URLs will be publicly accessible
# SHARE_SESSIONS=true

# Proxy Configuration (optional)
# Use these if you need to access OpenAI API through a proxy
# Can also be set via CLI: --proxy http://192.168.1.100:7890
# HTTP_PROXY=http://192.168.1.100:7890
# HTTPS_PROXY=http://192.168.1.100:7890
# ALL_PROXY=http://192.168.1.100:7890
